# Build-time tenant selection (required)
# TENANT_ID=resort-example
TENANT_ID=vukans-bike

# Runtime mode
NODE_ENV=development

# Optional webhook revalidation secret
REVALIDATE_SECRET=replace-with-a-strong-secret

# Strapi CMS (required when using Strapi adapter)
# STRAPI_URL=http://localhost:1337
# STRAPI_API_TOKEN=replace-with-strapi-api-token

# Optional preview secret
# PREVIEW_SECRET=replace-with-preview-secret

# Tenant-specific integration examples
# RESORT_BOOKING_API_URL=https://api.booking-provider.com
# RESORT_BOOKING_API_KEY=replace-with-booking-api-key
