{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@core/*": [
        "./src/core/*"
      ],
      "@tenants/*": [
        "./src/tenants/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@tenant/*": [
        "./src/tenants/vukans-bike/*"
      ],
      "@mock-data/*": [
        "./src/core/mock-data.ts/vukans-bike/*"
      ],
      "@tenant": [
        "./src/tenants/vukans-bike"
      ],
      "@mock-data": [
        "./src/core/mock-data.ts/vukans-bike"
      ]
    },
    "target": "ES2017"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-vukans-bike/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
